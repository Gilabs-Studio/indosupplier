# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8088
# NEXT_PUBLIC_API_URL=

# POS app download links (R2/public HTTPS URL)
# Option A: single JSON map
# NEXT_PUBLIC_POS_DOWNLOAD_LINKS={"windows":"https://<your-r2-domain>/pos/windows/latest/Indosupplier-POS-Setup.exe","android":"https://<your-r2-domain>/pos/android/latest/app-release.apk"}
# Option B: per-platform keys
# NEXT_PUBLIC_POS_DOWNLOAD_WINDOWS_URL=
# NEXT_PUBLIC_POS_DOWNLOAD_ANDROID_URL=
# NEXT_PUBLIC_POS_DOWNLOAD_MACOS_URL=
# NEXT_PUBLIC_POS_DOWNLOAD_LINUX_URL=

# N8N Configuration (Override local API url for Docker n8n so it doesn't use localhost)
NEXT_PUBLIC_N8N_ERP_BASE_URL=http://172.17.0.1:8088
# Environment
NODE_ENV=development

UNSPLASH_ACCESS_KEY=
APOLLO_API_KEY=
SERPER_API_KEY=          
APIFY_API_KEY=


