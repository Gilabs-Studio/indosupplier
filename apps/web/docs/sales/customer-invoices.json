          "PENDING": {
            "description": "Invoice is ready for payment",
            "allowed_operations": ["view", "create_payment"],
            "next_possible_status": ["PAID", "PARTIAL", "OVERDUE"],
            "business_rules": [
              "Journal entries posted (AR and Revenue)",
              "Ready for payment processing",
              "Cannot be updated or deleted"
            ],
            "color": "orange"
          },
          "PAID": {
            "description": "Invoice is fully paid",
            "allowed_operations": ["view"],
            "next_possible_status": [],
            "business_rules": [
              "Read-only status",
              "All payments completed",
              "Sales order may be closed"
            ],
            "color": "blue"
          },
          "PARTIAL": {
            "description": "Invoice is partially paid",
            "allowed_operations": ["view", "create_payment"],
            "next_possible_status": ["PAID"],
            "business_rules": [
              "Some payments received",
              "Can accept additional payments",
              "Shows remaining balance"
            ],
            "color": "green"
          },
          "OVERDUE": {
            "description": "Invoice is past due date",
            "allowed_operations": ["view", "create_payment"],
            "next_possible_status": ["PAID", "PARTIAL"],
            "business_rules": [
              "Past due date",
              "Can still accept payments",
              "May require follow-up"
            ],
            "color": "red"
          }
        }
