    {
      "title": "STATUS DEFINITIONS",
      "status_definitions": {
        "payment_status": {
          "PENDING": {
            "description": "Payment created but not yet confirmed",
            "allowed_operations": ["confirm", "delete"],
            "next_possible_status": ["CONFIRMED"],
            "business_rules": [
