      "title": "STATUS DEFINITIONS",
      "status_definitions": {
        "invoice_status": {
          "DRAFT": {
            "description": "Invoice Down Payment created but not yet finalized",
            "allowed_operations": ["update", "set_pending", "delete"],
            "next_possible_status": ["PENDING"],
            "business_rules": [
              "Can be updated or deleted",
              "Not yet ready for payment",
              "Journal entries not posted yet"
            ],
            "color": "gray"
          },
          "PENDING": {
            "description": "Invoice Down Payment is ready for payment",
            "allowed_operations": ["view", "create_payment"],
            "next_possible_status": ["PAID", "PARTIAL", "OVERDUE"],
            "business_rules": [
              "Journal entries posted (AR and Revenue)",
              "Ready for payment processing",
              "Cannot be updated or deleted"
            ],
            "color": "orange"
          },
          "PAID": {
            "description": "Invoice Down Payment is fully paid",
            "allowed_operations": ["view"],
            "next_possible_status": [],
            "business_rules": [
              "Read-only status",
              "All payments completed",
              "Sales order may be closed"
            ],
            "color": "blue"
          },
          "PARTIAL": {
            "description": "Invoice Down Payment is partially paid",
            "allowed_operations": ["view", "create_payment"],
            "next_possible_status": ["PAID"],
            "business_rules": [
              "Some payments received",
              "Can accept additional payments",
              "Shows remaining balance"
            ],
            "color": "green"
          },
          "OVERDUE": {
            "description": "Invoice Down Payment is past due date",
