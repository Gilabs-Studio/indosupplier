    {
      "title": "STATUS DEFINITIONS",
      "status_definitions": {
        "sales_order_status": {
          "DRAFT": {
            "description": "Initial status when sales order is created",
            "allowed_operations": ["update", "delete", "confirm"],
            "next_possible_status": ["APPROVED"],
            "business_rules": [
              "Can be updated or deleted",
              "Cannot create delivery orders or invoices",
              "Must be confirmed before proceeding to next steps"
            ],
            "color": "gray"
          },
          "APPROVED": {
            "description": "Sales order has been confirmed and ready for processing",
            "allowed_operations": [
              "view",
              "create_delivery_order",
              "create_invoice"
            ],
            "next_possible_status": ["CLOSED"],
            "business_rules": [
              "Cannot be updated or deleted",
              "Can create delivery orders and invoices",
              "Ready for fulfillment process"
            ],
            "color": "green"
          },
          "REVISED": {
            "description": "Sales order has been revised and need to be edited",
            "allowed_operations": ["view", "update"],
            "next_possible_status": ["DRAFT"],
            "business_rules": [
              "Cannot be updated or deleted",
              "Can be updated",
              "Ready for fulfillment process"
            ],
            "color": "orange"
          },
          "CLOSED": {
            "description": "Sales order is completed (delivered and paid)",
            "allowed_operations": ["view"],
            "next_possible_status": [],
            "business_rules": [
              "Read-only status",
              "All related processes completed",
              "Cannot be modified"
            ],
            "color": "blue"
          }
        },
        "delivery_status": {
          "NOT_CREATED": {
            "description": "Initial status when delivery order is not created",
            "next_possible_status": ["PENDING"],
            "color": "gray"
          },
          "PENDING": {
            "description": "Delivery order has been created and waiting for shipping",
            "next_possible_status": ["SHIPPED"],
            "color": "orange"
          },
          "SHIPPED": {
            "description": "Delivery order has been shipped",
            "next_possible_status": ["DELIVERED"],
            "color": "green"
          },
          "DELIVERED": {
            "description": "Delivery order has been delivered",
            "next_possible_status": [],
            "color": "blue"
          }
        },
        "invoice_status": {
          "NOT_CREATED": {
            "description": "Initial status when invoice is not created",
            "next_possible_status": ["PENDING"],
            "color": "gray"
          },
          "PENDING": {
            "description": "Invoice has been created and waiting for payment",
            "next_possible_status": ["PAID", "PARTIAL", "OVERDUE"],
            "color": "orange"
          },
          "PAID": {
            "description": "Invoice has been paid",
            "next_possible_status": [],
            "color": "blue"
          },
          "PARTIAL": {
            "description": "Invoice is partially paid",
            "next_possible_status": ["PAID"],
            "color": "green"
          },
          "OVERDUE": {
            "description": "Invoice is past due date",
            "next_possible_status": ["PAID", "PARTIAL"],
            "color": "red"
          }
        }
      }
