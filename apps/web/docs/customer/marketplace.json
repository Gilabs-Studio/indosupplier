      "create_review": {
        "method": "POST",
        "url": "/customer/marketplace/review",
        "description": "Create a new review for a product from a quotation",
        "authentication": "Required",
        "content_type": "application/json or multipart/form-data",
        "request_body": {
          "product_id": {
            "type": "uint",
            "description": "Product ID",
            "required": true,
            "example": 1
          },
          "quotation_id": {
            "type": "uint",
            "description": "Quotation ID",
            "required": true,
            "example": 1
          },
          "rating": {
            "type": "int8",
            "description": "Rating value (1-5)",
            "required": true,
            "min_value": 1,
            "max_value": 5,
            "example": 5
          },
          "title": {
            "type": "string",
            "description": "Review title",
            "required": false,
            "max_length": 255,
            "example": "Great Product!"
          },
          "content": {
            "type": "string",
            "description": "Review content",
            "required": false,
            "example": "This product is excellent quality."
          },
          "media_urls": {
            "type": "array",
            "description": "Array of media URLs (for JSON requests)",
            "required": false,
            "items": {
              "type": "string",
              "example": "https://example.com/review-image.jpg"
            }
          },
          "media": {
            "type": "file",
            "description": "Media files (for multipart/form-data requests)",
            "required": false,
            "example": "File upload"
          }
        },
        "response": {
          "status_code": 201,
          "content_type": "application/json",
          "body": {
            "message": "review created successfully",
            "data": {
              "id": 1,
              "product_id": 1,
              "quotation_id": 1,
              "rating": 5,
              "title": "Great Product!",
              "status": "APPROVED"
            }
          }
        },
        "error_responses": {
          "400": {
            "description": "Bad request - Invalid input data or business rule violation",
            "body": {
              "error": "product_id, quotation_id, and rating are required"
            }
          },
          "401": {
            "description": "Unauthorized",
            "body": {
              "error": "unauthorized"
            }
          },
          "404": {
            "description": "Not found",
            "body": {
              "error": "customer not found for this user"
            }
          },
          "409": {
            "description": "Conflict - Review already exists",
            "body": {
              "error": "review already exists for this product in this quotation"
            }
          },
          "500": {
            "description": "Internal server error",
            "body": {
              "error": "Error message"
            }
          }
        }
      }
