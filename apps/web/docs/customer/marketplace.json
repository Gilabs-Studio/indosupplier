{
  "marketplace_api_documentation": {
    "api_endpoints": {
      "get_products": {
        "method": "GET",
        "url": "/customer/marketplace/product",
        "description": "Get paginated list of approved products",
        "authentication": "Not required",
        "query_parameters": {
          "page": {
            "type": "int",
            "description": "Page number for pagination",
            "required": false,
            "default": 1,
            "min_value": 1,
            "example": 1
          },
          "limit": {
            "type": "int",
            "description": "Number of items per page",
            "required": false,
            "default": 10,
            "min_value": 1,
            "max_value": 100,
            "example": 10
          },
          "search": {
            "type": "string",
            "description": "Search by product name",
            "required": false,
            "example": "product name"
          },
          "sort": {
            "type": "string",
            "description": "Sort by selling price",
            "required": false,
            "enum_values": ["highest", "lowest"],
            "example": "highest"
          },
          "category_id": {
            "type": "uint",
            "description": "Filter by product category ID",
            "required": false,
            "example": 1
          }
        },
        "response": {
          "status_code": 200,
          "content_type": "application/json",
          "body": {
            "data": [
              {
                "id": 1,
                "name": "Product Name",
                "code": "PRD-001",
                "catalog_number": "CAT-001",
                "image_url": "https://example.com/image.jpg",
                "selling_price": 150000.00,
                "stock": 100
              }
            ],
            "meta": {
              "pagination": {
                "total": 100,
                "page": 1,
                "limit": 10
              },
              "search": {
                "search": ""
              },
              "sort": {
                "sort_by": ""
              },
              "filter": {
                "category_id": ""
              },
              "product_categories": [
                {
                  "id": 1,
                  "name": "Category Name"
                }
              ]
            }
          }
        },
        "error_responses": {
          "500": {
            "description": "Internal server error",
            "body": {
              "error": "Error message"
            }
          }
        }
      },
