      "buy_now": {
        "method": "POST",
        "url": "/customer/marketplace/buy-now",
        "description": "Create a sales quotation from marketplace buy now",
        "authentication": "Required",
        "content_type": "application/json",
        "request_body": {
          "notes": {
            "type": "string",
            "description": "Optional notes for the quotation",
            "required": false,
            "example": "Please deliver as soon as possible"
          },
          "items": {
            "type": "array",
            "description": "List of items to purchase",
            "required": true,
            "items": {
              "product_id": {
                "type": "uint",
                "description": "Product ID",
                "required": true,
                "example": 1
              },
              "quantity": {
                "type": "int",
                "description": "Quantity to purchase",
                "required": true,
                "min_value": 1,
                "example": 2
              },
              "price": {
                "type": "float64",
                "description": "Price per unit",
                "required": true,
                "min_value": 0,
                "example": 150000.00
              }
            }
          }
        },
        "response": {
          "status_code": 201,
          "content_type": "application/json",
          "body": {
            "message": "quotation created",
            "data": {
              "id": 1,
              "code": "SQ-20240101-0001",
