{
  "cart_api_documentation": {
    "api_endpoints": {
      "get_cart_items": {
        "method": "GET",
        "url": "/customer/cart-items",
        "description": "Get all cart items for the authenticated customer",
        "authentication": "Required",
        "response": {
          "status_code": 200,
          "content_type": "application/json",
          "body": {
            "data": [
              {
                "id": 1,
                "quantity": 2,
                "product": {
                  "id": 1,
                  "name": "Product Name",
                  "code": "PRD-001",
                  "catalog_number": "CAT-001",
                  "image_url": "https://example.com/image.jpg",
                  "selling_price": 150000.00
                },
                "created_at": "2024-01-01T00:00:00Z",
                "updated_at": "2024-01-01T00:00:00Z"
              }
            ]
          }
        },
        "error_responses": {
          "401": {
            "description": "Unauthorized",
            "body": {
              "error": "unauthorized"
            }
          },
          "404": {
            "description": "Customer not found",
            "body": {
              "error": "customer not found for this user"
            }
          },
          "500": {
            "description": "Internal server error",
            "body": {
              "error": "Error message"
            }
          }
        }
      },
      "get_cart_item_by_id": {
        "method": "GET",
        "url": "/customer/cart-items/:id",
        "description": "Get a single cart item by ID (only if it belongs to the authenticated customer)",
        "authentication": "Required",
        "path_parameters": {
          "id": {
            "type": "uint",
            "description": "Cart item ID",
            "required": true,
            "example": 1
          }
        },
        "response": {
          "status_code": 200,
          "content_type": "application/json",
          "body": {
            "data": {
              "id": 1,
              "quantity": 2,
              "product": {
                "id": 1,
                "name": "Product Name",
                "code": "PRD-001",
                "catalog_number": "CAT-001",
                "image_url": "https://example.com/image.jpg",
                "selling_price": 150000.00
              },
              "created_at": "2024-01-01T00:00:00Z",
              "updated_at": "2024-01-01T00:00:00Z"
            }
          }
        },
        "error_responses": {
          "400": {
            "description": "Bad request - Invalid cart item id",
            "body": {
              "error": "invalid cart item id"
            }
          },
          "401": {
            "description": "Unauthorized",
            "body": {
              "error": "unauthorized"
            }
          },
          "403": {
            "description": "Forbidden - Cart item does not belong to the customer",
            "body": {
              "error": "access denied"
            }
          },
          "404": {
            "description": "Cart item not found",
            "body": {
              "error": "cart item not found"
            }
          },
          "500": {
            "description": "Internal server error",
            "body": {
              "error": "Error message"
            }
          }
        }
      },
