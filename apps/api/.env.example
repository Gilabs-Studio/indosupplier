# ===========================================
# GIMS ERP - Development Environment Variables
# ===========================================
# Copy this file to .env for local development
#
# USAGE OPTIONS:
# 1. Full Docker Stack (API + DB + Redis):
#    cp .env.example .env
#    docker-compose up -d
#
# 2. Local Go + Docker DB only (recommended for daily dev):
#    cp .env.example .env
#    Uncomment LOCAL_GO_MODE section below
#    docker compose up -d postgres redis
#    air                    # hot reload (requires: go install github.com/air-verse/air@latest)
# ===========================================

# Server Configuration
PORT=8081
APP_ENV=development  # Options: development, staging, production
APP_TIMEZONE=Asia/Jakarta  # IANA timezone (e.g., Asia/Jakarta, America/New_York, Europe/London)
GIN_MODE=debug

# Startup Behavior
RUN_MIGRATIONS=true  # Auto-run migrations on startup
RUN_SEEDERS=true     # Auto-run seeders on startup (NEVER set to true in production)

# Database Configuration
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=gims_erp
DB_SSLMODE=disable
DB_PORT=5434  # External port exposed by Docker (maps to internal 5432)

# ===========================================
# LOCAL_GO_MODE - Uncomment for local Go dev (air / go run)
# ===========================================
# When running Go locally (not inside Docker), you need to
# point DB and Redis to localhost with the Docker-exposed ports.
#
# DB_HOST=localhost
# DB_PORT=5434
# REDIS_HOST=localhost
# ===========================================

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production-min-32-chars
JWT_ACCESS_TTL=24
JWT_REFRESH_TTL=7

# Cerebras AI Configuration
CEREBRAS_BASE_URL=https://api.cerebras.ai
CEREBRAS_API_KEY=your-cerebras-api-key-here

# Redis Configuration
REDIS_PORT=6378
REDIS_PASSWORD=
REDIS_DB=0

# Storage Configuration
STORAGE_MAX_UPLOAD_SIZE=10485760

# Cloudflare R2
# R2_ACCOUNT_ID:       Cloudflare account ID (found in the dashboard URL: dash.cloudflare.com/<account_id>)
# R2_ACCESS_KEY_ID:    R2 API token access key ID (Manage R2 API Tokens)
# R2_SECRET_ACCESS_KEY: R2 API token secret access key
# R2_BUCKET_NAME:      Name of the R2 bucket
# R2_PUBLIC_URL:       Public URL prefix for accessing bucket objects
#                      e.g. https://pub-abc123.r2.dev  or  https://cdn.yourdomain.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Seeder Configuration
SEED_CLEANUP_DATABASE=false
SEED_ONLY_MASTER_DATA=false  # true = run only auth + master data seeders
SEED_MINIMAL_DATA=false      # true = generate a small traceable dataset (SQ→SO→DO→INV→PAY and PO→GR→SI→PAY)
SEED_DEFAULT_EMAIL=admin@example.com
SEED_DEFAULT_PASSWORD=admin123

# Finance validation (use validate_finance tool)
VALIDATE_FINANCE_START=
VALIDATE_FINANCE_END=

# n8n Automation Configuration (self-hosted or n8n.cloud)
N8N_LEADS_WEBHOOK_URL=https://your-instance.n8n.cloud/webhook/gims-leads

# Xendit Payment Gateway
# XENDIT_SECRET_KEY: Server-side API key from Xendit Dashboard → Settings → API Keys
# XENDIT_WEBHOOK_TOKEN: Callback token from Xendit Dashboard → Settings → Webhooks
# XENDIT_BASE_URL: Override to https://api.xendit.co/sandbox for sandbox testing (omit for production)
XENDIT_SECRET_KEY=xnd_development_your_secret_key_here
XENDIT_WEBHOOK_TOKEN=your-xendit-webhook-callback-token-here
XENDIT_CREDENTIAL_ENCRYPTION_KEY=your-32-byte-encryption-key-here